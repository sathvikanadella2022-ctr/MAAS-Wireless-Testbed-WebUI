// Prisma schema for 5G Portal
// Run `npx prisma migrate dev --name init` after editing

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      Role     @default(RESEARCHER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  reservations Reservation[]
  deployments  Deployment[]
  auditLogs  AuditLog[]
  terminalSessions TerminalSession[]
}

enum Role {
  RESEARCHER
  ADMIN
}

model Reservation {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  resource  String
  startTime DateTime
  endTime   DateTime
  project   String
  purpose   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Deployment {
  id          String           @id @default(uuid())
  user        User?            @relation(fields: [userId], references: [id])
  userId      String?
  resource    String
  imageId     String
  imageName   String
  requestedBy String
  scheduledAt DateTime
  notes       String?
  status      DeploymentStatus @default(QUEUED)
  createdAt   DateTime         @default(now())
}

enum DeploymentStatus {
  QUEUED
  DEPLOYING
  READY
  FAILED
}

model AuditLog {
  id        String   @id @default(uuid())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  event     String
  details   String?
  createdAt DateTime @default(now())
}

model TerminalSession {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  resource  String
  startedAt DateTime @default(now())
  endedAt   DateTime?
  logPath   String?
}
